{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": ["node"],
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": [
    "supabase/functions/**/*.ts",
    "supabase/functions/**/*.d.ts"
  ]
}
